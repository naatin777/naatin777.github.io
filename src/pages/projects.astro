---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import ProjectCard from "@components/card/ProjectCard.astro";
import ProjectTagCard from "@components/card/ProjectTagCard.astro";
import { projectsCardList, projectsPageBody, projectsPageLayout, projectsPageTitle } from "@styles/pages/projects.css";

const projects = await getCollection("projects");
const allTags = projects.flatMap((project) => project.data.tags);
const uniqueTags = [...new Set(allTags)].sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
---

<Layout title="Projects" description="A list of personal projects and experiments.">
  <section class={projectsPageBody}>
    <h1 class={projectsPageTitle}>Projects</h1>
    <div class={projectsPageLayout}>
      <ProjectTagCard tags={uniqueTags} />
      <ul class={projectsCardList} id="projects-list">
        {
          projects.map((project) => (
            <li data-tags={project.data.tags.join(",")}>
              <ProjectCard project={project} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<script>
  import { $projectTags } from "../stores/projects";

  function applyFilter(selectedTags: string[]) {
    const items = document.querySelectorAll<HTMLElement>("#projects-list > [data-tags]");
    for (const item of items) {
      if (selectedTags.length === 0) {
        item.hidden = false;
      } else {
        const itemTags = (item.dataset.tags ?? "").split(",").filter(Boolean);
        item.hidden = !selectedTags.some((t) => itemTags.includes(t));
      }
    }
  }

  $projectTags.subscribe(applyFilter);
</script>
