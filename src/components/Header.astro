---
import ThemeToggle from "@components/ThemeToggle.tsx";
import {
  headerActions,
  headerInner,
  siteBrand,
  siteHeader,
  siteNav,
  siteNavLink,
  siteNavList,
} from "@components/Header.css";

const navItems = [
  { href: "/changelog/", label: "Changelog" },
  { href: "/projects/", label: "Projects" },
  { href: "/articles/", label: "Articles" },
] as const;

const pathname = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === "/articles/") return pathname.startsWith("/articles/") || pathname.startsWith("/blog/");
  return pathname === href || pathname.startsWith(href);
};
---

<header class={siteHeader}>
  <div class={headerInner}>
    <a href="/" class={siteBrand} aria-label="Home">naatin777.dev</a>

    <div class={headerActions}>
      <ThemeToggle client:load />
    </div>

    <nav class={siteNav} aria-label="Primary">
      <ul class={siteNavList}>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class={siteNavLink} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
