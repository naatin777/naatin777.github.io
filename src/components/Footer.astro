---
import { copyright, footer, socialIsland, socialLinkGroup } from "./Footer.css";
import SocialLink from "./SocialLink.astro";
import { socialLinks } from "@config/social";
import { author } from "@config/author";

const year = new Date().getFullYear();
---

<footer class={footer}>
  <div class={socialIsland}>
    <div class={socialLinkGroup}>
      {socialLinks.map((link) => <SocialLink {...link} />)}
    </div>
  </div>
  <p class={copyright}>&copy; {year} {author.displayName}. All Rights Reserved.</p>
</footer>
