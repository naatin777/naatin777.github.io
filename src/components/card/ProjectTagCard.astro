---
import { card } from "@components/card/Card.css";
import TagFilter from "@components/card/TagFilter";
import { tagCard } from "@components/card/TagCard.css";

export interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<aside class:list={[card, tagCard]}>
  <TagFilter
    kind="project"
    tags={tags}
    queryKey="projectTags"
    listSelector="#projects-list > [data-tags]"
    client:load
  />
</aside>
